{\n  \"name\": \"@creach-t/meshy-mcp-server\",\n  \"version\": \"0.3.1\",\n  \"description\": \"Custom Meshy MCP Server — fork with image URL fix\",\n  \"type\": \"module\",\n  \"main\": \"dist/index.js\",\n  \"types\": \"dist/index.d.ts\",\n  \"bin\": { \"meshy-mcp-server\": \"dist/index.js\" },\n  \"files\": [\"dist/\", \"LICENSE\", \"README.md\", \".env.example\"],\n  \"scripts\": {\n    \"start\": \"node dist/index.js\",\n    \"dev\": \"tsx watch src/index.ts\",\n    \"build\": \"tsc\",\n    \"clean\": \"rm -rf dist\",\n    \"lint\": \"tsc --noEmit\",\n    \"prepublishOnly\": \"npm run clean && npm run build\"\n  },\n  \"engines\": { \"node\": \">=18\" },\n  \"repository\": { \"type\": \"git\", \"url\": \"git+https://github.com/creach-t/meshy-mcp-server.git\" },\n  \"author\": \"creach-t\",\n  \"license\": \"MIT\",\n  \"dependencies\": {\n    \"@modelcontextprotocol/sdk\": \"^1.6.1\",\n    \"axios\": \"^1.7.9\",\n    \"dotenv\": \"^17.3.1\",\n    \"express\": \"^4.18.2\",\n    \"zod\": \"^3.23.8\"\n  },\n  \"devDependencies\": {\n    \"@types/express\": \"^4.17.21\",\n    \"@types/node\": \"^22.10.0\",\n    \"tsx\": \"^4.19.2\",\n    \"typescript\": \"^5.7.2\"\n  }\n}\n